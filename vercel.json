{
  "version": 2,
  "outputDirectory": "public",
  "regions": [
    "sin1"
  ],
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/favicon.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "build": {
    "env": {
      "APP_ENV": "production",
      "APP_DEBUG": "false"
    }
  },
  "env": {
    "APP_NAME": "FoodOrderingAPI",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_KEY": "base64:431VmB8uVpGqkp8yjKIJpEjtUr8NjI5enqdbXYRWpIk=",
    "APP_URL": "https://vhsitekh.site",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "gateway01.ap-southeast-1.prod.aws.tidbcloud.com",
    "DB_PORT": "4000",
    "DB_DATABASE": "hsite_system_api",
    "DB_USERNAME": "EqyMtPi63u9wFEb.root",
    "DB_PASSWORD": "vDz5l9R1W4EZk4WB",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "database",
    "QUEUE_CONNECTION": "sync",
    "BROADCAST_CONNECTION": "log",
    "FILESYSTEM_DISK": "local",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp"
  }
}

